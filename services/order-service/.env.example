# Application
NODE_ENV=development
PORT=8003
CORS_ORIGIN=*
LOG_LEVEL=info

# Database
DATABASE_URL=postgres://emp:emp@postgres-order:5432/emp_order
DATABASE_HOST=postgres-order
DATABASE_PORT=5432
DATABASE_USERNAME=emp
DATABASE_PASSWORD=emp
DATABASE_NAME=emp_order
DATABASE_SSL=false

# Redis
REDIS_URL=redis://redis-master:6379/0
REDIS_HOST=redis-master
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# RabbitMQ
RABBITMQ_URL=amqp://emp:emp@rabbitmq:5672
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=emp
RABBITMQ_PASSWORD=emp
RABBITMQ_ORDER_EXCHANGE=order.exchange
RABBITMQ_PAYMENT_EXCHANGE=payment.exchange
RABBITMQ_ORDER_QUEUE=order.events
RABBITMQ_PAYMENT_QUEUE=order.payment.queue
RABBITMQ_PAYMENT_DLQ=order.payment.queue.dlq

# Auth Service (for JWKS)
AUTH_SERVICE_URL=http://auth-service:8001
JWT_ISSUER=http://localhost:8001
JWT_AUDIENCE=emp-platform

# OpenTelemetry
OTEL_SERVICE_NAME=order-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
