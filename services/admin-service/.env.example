# Database
DATABASE_URL="postgresql://emp_admin:emp_admin_password@localhost:5432/emp_admin?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_SENTINEL_HOSTS=localhost:26379
REDIS_SENTINEL_MASTER=mymaster

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin_password@localhost:5672/emp.admin
RABBITMQ_QUEUE_PREFIX=admin

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-jwt-refresh-secret-key-here
JWT_REFRESH_EXPIRES_IN=7d

# Auth Service Integration
AUTH_SERVICE_URL=http://localhost:8000
AUTH_SERVICE_JWKS_URL=http://localhost:8000/.well-known/jwks.json

# External Services
PRODUCT_SERVICE_URL=http://localhost:8001
ORDER_SERVICE_URL=http://localhost:8002
INVENTORY_SERVICE_URL=http://localhost:8003
PAYMENT_SERVICE_URL=http://localhost:8006

# OpenTelemetry
OTEL_SERVICE_NAME=admin-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_PROMETHEUS_ENDPOINT=http://localhost:9090/metrics
OTEL_RESOURCE_ATTRIBUTES=service.name=admin-service,service.version=1.0.0,deployment.environment=development

# Application Configuration
PORT=8007
NODE_ENV=development
API_PREFIX=api/v1

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# CORS
CORS_ORIGIN=http://localhost:3000,http://localhost:8008

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=image/jpeg,image/png,image/webp

# Encryption
ENCRYPTION_KEY=your-32-byte-encryption-key-here

# Logging
LOG_LEVEL=debug
LOG_FORMAT=json

# Health Check
HEALTH_CHECK_INTERVAL=30000