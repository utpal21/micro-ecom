{
    "$schema": "https://json.schemastore.org/nest-cli",
    "collection": "@nestjs/schematics",
    "sourceRoot": "src",
    "compilerOptions": {
        "deleteOutDir": true,
        "webpack": true,
        "plugins": [
            {
                "name": "@nestjs/swagger",
                "options": {
                    "classValidatorShim": true,
                    "introspectComments": true,
                    "controller": {
                        "decorators": [
                            {
                                "name": "ApiTags",
                                "arguments": "['{controllerName}']"
                            }
                        ]
                    }
                }
            }
        ]
    }
}