# Node Environment
NODE_ENV=development
PORT=3004

# Database
DATABASE_URL=postgresql://payment_user:payment_password@localhost:5432/payment_service?schema=public

# JWT Configuration
JWT_ISSUER=https://auth.microecom.local
JWT_AUDIENCE=https://payment.microecom.local
JWKS_URL=https://auth.microecom.local/.well-known/jwks.json

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672
RABBITMQ_QUEUE_ORDER_CREATED=order.created
RABBITMQ_QUEUE_ORDER_CANCELLED=order.cancelled
RABBITMQ_EXCHANGE_EVENTS=events

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=


# SSLCommerz Sandbox Credentials
SSLCOMMERZ_STORE_ID=adico69edf12582d67
SSLCOMMERZ_STORE_PASSWORD=adico69edf12582d67@ssl
SSLCOMMERZ_SANDBOX=true
SSLCOMMERZ_IPN_URL=http://localhost:3004/api/v1/webhooks/sslcommerz

# Stripe Configuration
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# OpenTelemetry
OTEL_SERVICE_NAME=payment-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# CORS
CORS_ORIGIN=http://localhost:3000,https://web.microecom.local