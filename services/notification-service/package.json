{
    "name": "@emp/notification-service",
    "version": "1.0.0",
    "description": "Notification Service - Async Email/SMS Dispatch",
    "main": "dist/main.js",
    "scripts": {
        "build": "tsc",
        "start": "node dist/main.js",
        "dev": "ts-node src/main.ts",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "lint": "eslint src --ext .ts",
        "lint:fix": "eslint src --ext .ts --fix",
        "format": "prettier --write \"src/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "keywords": [
        "notification",
        "email",
        "sms",
        "rabbitmq",
        "redis"
    ],
    "author": "Enterprise Marketplace Platform",
    "license": "PROPRIETARY",
    "dependencies": {
        "@emp/shared-types": "workspace:*",
        "@emp/utils": "workspace:*",
        "@opentelemetry/api": "^1.9.0",
        "@opentelemetry/exporter-prometheus": "^0.52.0",
        "@opentelemetry/instrumentation": "^0.52.0",
        "@opentelemetry/instrumentation-amqplib": "^0.40.0",
        "@opentelemetry/instrumentation-http": "^0.52.0",
        "@opentelemetry/sdk-metrics": "^1.24.0",
        "@opentelemetry/sdk-node": "^0.52.0",
        "amqplib": "^0.10.3",
        "amqp-connection-manager": "^4.1.14",
        "dotenv": "^16.4.5",
        "ioredis": "^5.4.1",
        "nodemailer": "^6.9.13",
        "pino": "^9.0.0",
        "prom-client": "^15.1.0",
        "twilio": "^5.0.3",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@types/amqplib": "^0.10.5",
        "@types/jest": "^29.5.12",
        "@types/node": "^20.12.7",
        "@types/nodemailer": "^6.4.14",
        "@types/supertest": "^6.0.2",
        "@typescript-eslint/eslint-plugin": "^7.7.0",
        "@typescript-eslint/parser": "^7.7.0",
        "eslint": "^8.57.0",
        "eslint-config-prettier": "^9.1.0",
        "jest": "^29.7.0",
        "prettier": "^3.2.5",
        "supertest": "^6.3.4",
        "ts-jest": "^29.1.2",
        "ts-node": "^10.9.2",
        "typescript": "^5.4.5"
    },
    "engines": {
        "node": ">=22.0.0",
        "pnpm": ">=8.0.0"
    }
}