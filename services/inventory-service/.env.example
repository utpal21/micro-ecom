# ============================================
# Database Configuration
# ============================================
DB_HOST=postgres-inventory
DB_PORT=5432
DB_NAME=emp_inventory
DB_USER=emp
DB_PASSWORD=emp

# ============================================
# Application Configuration
# ============================================
NODE_ENV=development
PORT=8004
SERVICE_NAME=inventory-service

# ============================================
# Redis Configuration
# ============================================
REDIS_HOST=redis-master
REDIS_PORT=6379

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_URI=amqp://emp:emp@rabbitmq:5672
RABBITMQ_QUEUE=inventory_events

# ============================================
# JWT & Auth Configuration
# ============================================
AUTH_SERVICE_URL=http://auth-service:8001
JWT_ISSUER=http://localhost:8001
JWT_AUDIENCE=emp-platform
JWKS_URL=http://auth-service:8001/api/.well-known/jwks.json

# ============================================
# OpenTelemetry Configuration
# ============================================
OTEL_SERVICE_NAME=inventory-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
METRICS_PORT=9465

# ============================================
# CORS Configuration
# ============================================
FRONTEND_URL=http://localhost:3000

# ============================================
# Throttling Configuration
# ============================================
THROTTLE_TTL=60
THROTTLE_LIMIT=100