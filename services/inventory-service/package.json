{
    "name": "inventory-service",
    "version": "1.0.0",
    "description": "Inventory Service - Enterprise Marketplace Platform",
    "main": "dist/main.js",
    "scripts": {
        "prebuild": "rimraf dist",
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "migration:generate": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:generate -d src/config/typeorm.config.ts",
        "migration:run": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:run -d src/config/typeorm.config.ts",
        "migration:revert": "ts-node -r tsconfig-paths/register node_modules/.bin/typeorm migration:revert -d src/config/typeorm.config.ts"
    },
    "dependencies": {
        "@golevelup/nestjs-rabbitmq": "^5.0.0",
        "@nestjs/common": "^11.0.0",
        "@nestjs/config": "^4.0.0",
        "@nestjs/core": "^11.0.0",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/platform-express": "^11.0.0",
        "@nestjs/swagger": "^11.3.2",
        "@nestjs/throttler": "^6.0.0",
        "@nestjs/typeorm": "^11.0.0",
        "@opentelemetry/api": "^1.7.0",
        "@opentelemetry/auto-instrumentations-node": "^0.46.0",
        "@opentelemetry/exporter-prometheus": "^0.52.0",
        "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.0",
        "@opentelemetry/instrumentation": "^0.52.0",
        "@opentelemetry/instrumentation-express": "^0.36.0",
        "@opentelemetry/instrumentation-http": "^0.52.0",
        "@opentelemetry/instrumentation-pg": "^0.38.0",
        "@opentelemetry/resources": "^1.18.1",
        "@opentelemetry/sdk-metrics": "^1.18.1",
        "@opentelemetry/sdk-trace-node": "^1.18.1",
        "@opentelemetry/semantic-conventions": "^1.18.1",
        "amqplib": "^0.10.3",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.14.0",
        "ioredis": "^5.3.2",
        "joi": "^17.11.0",
        "jose": "^5.1.3",
        "pg": "^8.11.3",
        "prom-client": "^15.1.0",
        "redis": "^4.7.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "typeorm": "^0.3.19",
        "uuid": "^9.0.1",
        "zod": "^3.22.4"
    },
    "devDependencies": {
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.0",
        "@types/amqplib": "^0.10.4",
        "@types/express": "^4.17.21",
        "@types/jest": "^29.5.11",
        "@types/node": "^20.10.6",
        "@types/pg": "^8.10.9",
        "@types/supertest": "^7.2.0",
        "@types/uuid": "^9.0.7",
        "@typescript-eslint/eslint-plugin": "^6.17.0",
        "@typescript-eslint/parser": "^6.17.0",
        "eslint": "^8.56.0",
        "eslint-config-prettier": "^9.1.0",
        "eslint-plugin-prettier": "^5.1.2",
        "jest": "^29.7.0",
        "prettier": "^3.1.1",
        "rimraf": "^5.0.5",
        "source-map-support": "^0.5.21",
        "supertest": "^7.2.2",
        "ts-jest": "^29.1.1",
        "ts-loader": "^9.5.1",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.3.3"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node"
    }
}
