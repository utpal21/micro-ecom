# ============================================
# Enterprise Marketplace Platform (EMP)
# Environment Configuration Template
# ============================================
# Copy this file to .env and customize values
# DO NOT commit the actual .env file to version control

# ============================================
# Application Settings
# ============================================
APP_NAME="Enterprise Marketplace Platform"
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost

# ============================================
# Service Ports
# ============================================
AUTH_SERVICE_PORT=8001
PRODUCT_SERVICE_PORT=8002
ORDER_SERVICE_PORT=8003
INVENTORY_SERVICE_PORT=8004
PAYMENT_SERVICE_PORT=8005
NOTIFICATION_SERVICE_PORT=8006

# ============================================
# Database Configuration
# ============================================
POSTGRES_USER=emp
POSTGRES_PASSWORD=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_PASSWORD

POSTGRES_AUTH_PORT=5433
POSTGRES_ORDER_PORT=5434
POSTGRES_INVENTORY_PORT=5435
POSTGRES_PAYMENT_PORT=5436

# ============================================
# MongoDB Configuration
# ============================================
MONGODB_PORT=27017
MONGODB_USERNAME=emp
MONGODB_PASSWORD=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_PASSWORD

# ============================================
# Redis Configuration
# ============================================
REDIS_MASTER_PORT=6379
REDIS_PASSWORD=

REDIS_SENTINEL_1_PORT=26379
REDIS_SENTINEL_2_PORT=26380
REDIS_SENTINEL_3_PORT=26381

# ============================================
# RabbitMQ Configuration
# ============================================
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_USER=emp
RABBITMQ_PASSWORD=CHANGE_THIS_IN_PRODUCTION_USE_STRONG_PASSWORD

# ============================================
# Auth Service Configuration
# ============================================
# JWT Configuration
JWT_ISSUER=http://localhost:8001
JWT_PLATFORM_AUDIENCE=emp-platform
JWT_ACCESS_TOKEN_TTL_MINUTES=15
JWT_REFRESH_TOKEN_TTL_DAYS=7

# Service-to-Service Authentication
SERVICE_TOKEN_API_KEY=CHANGE_THIS_IN_PRODUCTION_USE_RANDOM_64_CHAR_STRING

# Security
BCRYPT_ROUNDS=12

# Application
APP_ENV=local
APP_DEBUG=true
APP_URL=http://localhost:8001
LOG_LEVEL=debug

# ============================================
# Security Notes
# ============================================
# 1. NEVER commit the actual .env file to version control
# 2. ALWAYS use strong passwords in production (minimum 32 characters)
# 3. Use Docker Secrets or Kubernetes Secrets for sensitive data in production
# 4. Rotate credentials regularly (every 90 days minimum)
# 5. Use different passwords for different services
# 6. Enable SSL/TLS for all external connections in production
# 7. Use environment-specific .env files (.env.development, .env.staging, .env.production)

# ============================================
# Development Notes
# ============================================
# - This file uses default values for local development
# - For production, override all default passwords
# - Consider using a secrets management solution (HashiCorp Vault, AWS Secrets Manager, etc.)
# - Enable APP_DEBUG=false in production
# - Set appropriate LOG_LEVEL in production (info or warning)