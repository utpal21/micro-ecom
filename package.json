{
  "name": "enterprise-marketplace-platform",
  "version": "0.1.0",
  "private": true,
  "description": "EMP monorepo foundation",
  "packageManager": "pnpm@10.8.0",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "build:shared-types": "tsc -p packages/shared-types/tsconfig.json",
    "build:utils": "tsc -p packages/utils/tsconfig.json",
    "build:event-bus": "tsc -p packages/event-bus/tsconfig.json",
    "build:packages": "pnpm build:shared-types && pnpm build:utils && pnpm build:event-bus",
    "infra:up": "docker compose up -d rabbitmq redis-master redis-replica-1 redis-replica-2 redis-sentinel-1 redis-sentinel-2 redis-sentinel-3 postgres-auth postgres-order postgres-inventory postgres-payment mongodb mongo-init-replica",
    "infra:down": "docker compose down",
    "infra:ps": "docker compose ps",
    "nginx:test": "docker run --rm -v $(pwd)/infrastructure/nginx/nginx.conf:/etc/nginx/nginx.conf:ro -v $(pwd)/infrastructure/nginx/conf.d:/etc/nginx/conf.d:ro nginx:1.25-alpine nginx -t",
    "swagger:registry": "node ./scripts/generate-swagger-registry.mjs"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.7",
    "@types/node": "^22.15.17",
    "typescript": "^5.8.3"
  }
}
